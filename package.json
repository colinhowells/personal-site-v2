{
	"name": "personal-site-v2",
	"version": "2.11.0",
	"description": "Colin Howells' personal website",
	"author": "Colin Howells",
	"private": true,
	"license": "UNLICENSED",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/colinhowells/personal-site-v2.git"
	},
	"type": "module",
	"packageManager": "pnpm@10.11.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"cf-typegen": "wrangler types",
		"cf-preview-prod": "pnpm run cf-typegen && pnpm run build && wrangler dev",
		"cf-preview-staging": "pnpm run cf-typegen && pnpm run build && wrangler dev --env staging"
	},
	"devDependencies": {
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.0",
		"@types/node": "^25.6.0",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.3",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prism-themes": "^1.9.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"temporal-polyfill": "^0.3.2",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"valibot": "^1.3.1",
		"vite": "^8.0.10",
		"wrangler": "^4.88.0"
	}
}
